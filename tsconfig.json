{
  "compilerOptions": {
    "target": "es2022",
    "module": "es2022",
    "moduleResolution": "bundler",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "types": [
      "node"
    ]
  },
  "include": [
    "spec/mcp/schema.ts",
    "gen/typescript/**/*.ts"
  ]
}